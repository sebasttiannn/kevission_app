# --- Flask ---
FLASK_APP=run.py
FLASK_DEBUG=0
SECRET_KEY=cambia_esto_por_una_clave_segura

# --- Base de datos ---
# Local (docker-compose): mysql+pymysql://kevission:kevission_pass@db:3306/kevission
# AWS RDS (producción, valor real lo entrega terraform output "rds_endpoint"):
# mysql+pymysql://usuario:password@<rds-endpoint>:3306/kevission
DATABASE_URI=sqlite:///local_kevission.db

# --- Almacenamiento de imágenes ---
# local  -> guarda en app/static/uploads (solo para desarrollo)
# azure  -> sube a Azure Blob Storage (requiere las 2 variables de abajo)
STORAGE_TYPE=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=kevission-prendas

# --- Clima ---
OPENWEATHER_KEY=tu_clave_api_aqui
